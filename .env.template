# Copy to .env and fill in values. Never commit .env.

# Supabase — get from: supabase.com → project → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon/publishable key>
SUPABASE_SERVICE_KEY=<service_role key — keep secret>
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Anthropic — get from: platform.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Tavily MCP — get from: app.tavily.com → API Keys → Generate MCP Link
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/?tavilyApiKey=tvly-...

# Alpha Vantage MCP — get from: alphavantage.co → Get API Key
# Free tier: 25 calls/day, 5 calls/min. MCP endpoint: https://mcp.alphavantage.co/mcp
ALPHA_VANTAGE_API_KEY=<your key>
