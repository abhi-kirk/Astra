# ── Supabase ──────────────────────────────────────────────────────────────────
# Free tier: 500 MB DB storage, unlimited API requests, 5 GB egress/month
# Projects pause after 1 week of inactivity (GitHub Actions heartbeat prevents this)
# Limit: 2 active projects on free plan
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_DB_URL=

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Current model: claude-sonnet-4-6 (set via REASONING_MODEL in config.py)
#
# Model comparison (per daily run ≈ 2-4K tokens in, ~800 tokens out):
#   claude-sonnet-4-6  $3/MTok in  + $15/MTok out  → ~$0.10/run → ~$2.20/month
#   claude-opus-4-6    $5/MTok in  + $25/MTok out   → ~$0.16/run → ~$3.50/month
#   claude-opus-4-8    $5/MTok in  + $25/MTok out   → ~$0.16/run → ~$3.50/month ← current (most capable)
# Rate limits are tier-based (Tier 1: 20K input TPM, 4K output TPM)
ANTHROPIC_API_KEY=

# ── Tavily MCP ────────────────────────────────────────────────────────────────
# Free tier: 1,000 API calls/month (resets 1st of each month)
# Each daily run uses up to TAVILY_MAX_SEARCHES (default 5) calls
# At 5 calls/run × 22 weekday runs/month = ~110 calls/month — well within free tier
TAVILY_MCP_URL=

# ── Alpha Vantage MCP ─────────────────────────────────────────────────────────
# Free tier: 25 calls/day, 5 calls/min
# MCP endpoint: https://mcp.alphavantage.co/mcp?apikey=YOUR_KEY
# Each daily run capped at ALPHA_VANTAGE_MAX_CALLS (default 8) to stay within daily limit
ALPHA_VANTAGE_API_KEY=

# ── SEC EDGAR MCP ──────────────────────────────────────────────────────────────
# Community-hosted endpoint (cyanheads/secedgar-mcp-server) — no API key required
# Tool: secedgar_get_insider_transactions (Form 3/4/5 insider activity)
# Rate limit: 10 req/sec; SEC fair-access policy requires a valid User-Agent (sent by MCP client)
# Note: community-hosted, not official — may go down; agent falls back gracefully if unavailable
# Override with SEC_EDGAR_MCP_URL if the endpoint changes
SEC_EDGAR_MCP_URL=https://secedgar.caseyjhand.com/mcp
